CORP_EXIT_PORT=0
CERT_VLESS_FULLCHAIN=/var/lib/clawpanel/certs/fullchain.pem
CERT_VLESS_KEY=/var/lib/clawpanel/certs/key.pem
CERT_HY2_FULLCHAIN=/var/lib/clawpanel/certs/fullchain.pem
CERT_HY2_KEY=/var/lib/clawpanel/certs/key.pem
XDNS_DOMAIN=t.__DOMAIN__
PANEL_HOST=__DOMAIN__:2083

# REALITY inbound (3rd protocol -- direct TCP, no nginx, no LE cert).
# Disabled by default. To enable:
#   1) generate keys:    xray-hy x25519       (PrivateKey + Password=PublicKey)
#   2) generate shortId: openssl rand -hex 8
#   3) set ENABLE_REALITY=1 and fill the keys below
#   4) open the port:    ufw allow <REALITY_PORT>/tcp
#   5) add "reality" to a user's enabled_protocols
# REALITY_DEST/SNI must be a real site with TLS1.3 + X25519 + H2 (e.g. ya.ru,
# www.microsoft.com). CLIENT SNI MUST EXACTLY MATCH REALITY_SNI or it won't connect.
ENABLE_REALITY=0
REALITY_PORT=8443
REALITY_DEST=www.microsoft.com:443
REALITY_SNI=www.microsoft.com
REALITY_PRIVATE_KEY=
REALITY_PUBLIC_KEY=
REALITY_SHORT_ID=
