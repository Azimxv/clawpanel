#!/usr/bin/env python3
"""Render /etc/hysteria/config.yaml from claw.db active users.

Called by claw-agent after every successful xray sync (or by hand).
Reloads hysteria.service if config changed.
"""
import sqlite3
import secrets
import subprocess
import sys
from pathlib import Path

DB = "/opt/clawpanel/data/claw.db"
CFG = Path("/etc/hysteria/config.yaml")
SETTING_HY2_OBFS_PASSWORD = "hy2_obfs_password"

TEMPLATE = """\
listen: :443

tls:
  cert: /var/lib/clawpanel/certs/fullchain.pem
  key: /var/lib/clawpanel/certs/key.pem
{obfs}
masquerade:
  type: file
  file:
    dir: /var/www/fake

auth:
  type: userpass
  userpass:
{users}

quic:
  initStreamReceiveWindow: 8388608
  maxStreamReceiveWindow: 8388608
  initConnReceiveWindow: 20971520
  maxConnReceiveWindow: 20971520

bandwidth:
  up: 1 gbps
  down: 1 gbps
"""

# Salamander obfuscation — makes the QUIC handshake look like random UDP so DPI
# can't fingerprint it. Password is shared with the client link (panel settings).
OBFS_BLOCK = """
obfs:
  type: salamander
  salamander:
    password: {password}
"""


def main() -> int:
    con = sqlite3.connect(DB)
    rows = con.execute(
        "SELECT username, xray_uuid FROM users "
        "WHERE is_active=1 AND (enabled_protocols LIKE '%hy2%' OR enabled_protocols='')"
    ).fetchall()
    obfs_pw_row = con.execute(
        "SELECT value FROM settings WHERE key=?", (SETTING_HY2_OBFS_PASSWORD,)
    ).fetchone()
    con.close()

    obfs = OBFS_BLOCK.format(password=obfs_pw_row[0]) if obfs_pw_row and obfs_pw_row[0] else ""

    if rows:
        users = "\n".join(f"    {u}: {p}" for u, p in rows)
    else:
        # hysteria rejects an empty userpass map; insert a dummy
        # credential that is never handed out to any client.
        users = f"    _placeholder: {secrets.token_hex(16)}"

    new_cfg = TEMPLATE.format(users=users, obfs=obfs)

    old_cfg = CFG.read_text() if CFG.exists() else ""
    if new_cfg == old_cfg:
        return 0

    CFG.write_text(new_cfg)
    CFG.chmod(0o640)

    r = subprocess.run(
        ["systemctl", "reload-or-restart", "hysteria.service"],
        capture_output=True, text=True
    )
    if r.returncode != 0:
        print(f"reload failed: {r.stderr}", file=sys.stderr)
        return 1
    print(f"hysteria config updated, {len(rows)} users")
    return 0


if __name__ == "__main__":
    sys.exit(main())
